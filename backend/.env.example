PORT=4000
JWT_SECRET=replace-with-strong-secret
DB_PATH=./data/pastalino.sqlite

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://app.yourdomain.com

# Optional SMTP for temporary password emails
# Gmail / Google Workspace mapping:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465 with SMTP_SECURE=true, or SMTP_PORT=587 with SMTP_SECURE=false
# SMTP_USER=your full Gmail or Workspace email address
# SMTP_PASS=an App Password from your Google account security settings
# SMTP_FROM=usually the same as SMTP_USER
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional Twilio SMS provider for appointment reminders
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional safe test destinations for `npm run notifications:test`
TEST_NOTIFICATION_EMAIL=
TEST_NOTIFICATION_PHONE=

# Automatic appointment reminder scheduler
APPOINTMENT_REMINDER_SCHEDULER_ENABLED=true
APPOINTMENT_REMINDER_INTERVAL_MINUTES=5
